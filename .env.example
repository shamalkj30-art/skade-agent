# Copy to .env and fill in. NEVER commit .env.

ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...        # used for voice-to-text (Scribe)

# LangSmith tracing (optional but recommended — every node + LLM call shows up
# in the LangSmith UI, which is invaluable for debugging agent flows).
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=skade-agent
